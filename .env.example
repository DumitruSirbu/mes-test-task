# Dev defaults only. Never reuse these values in shared, staging, or production environments.
# Generate per-env secrets via your secrets store (Vault, AWS Secrets Manager, GCP Secret Manager, etc.).
# Copy this file to `.env` before running `docker compose up`.

# ============================================================================
# Postgres (consumed by docker-compose and apps/backend)
# ============================================================================
POSTGRES_USER=mes
POSTGRES_PASSWORD=mes_dev_password
POSTGRES_DB=mes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# Redis (consumed by docker-compose and apps/backend via BullMQ)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=    # leave empty for local dev

# ============================================================================
# Backend (apps/backend)
# ============================================================================
NODE_ENV=development
BACKEND_PORT=3010

# JWT — REQUIRED in production; default below is dev-only
# generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_WITH_OPENSSL_RAND_HEX_32_BYTES_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Lowered from 15m → 10m per ADR 0007 (supersedes ADR 0003's original 15m default).
JWT_EXPIRES_IN=10m

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# CORS — comma-separated origin allow-list (read by main.ts and OriginAllowedGuard via CORS_ALLOWED_ORIGINS env var)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Invitation token signing
# 14 days; see docs/architecture/data-model.md
INVITATION_TOKEN_TTL_HOURS=336

# ============================================================================
# Frontends (apps/web, apps/admin) — read at build/runtime via VITE_*
# ============================================================================
WEB_PORT=5173
ADMIN_PORT=5174
VITE_API_BASE_URL=http://localhost:3010
