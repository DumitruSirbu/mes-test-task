# ============================================================================
# Postgres (consumed by docker-compose and apps/backend)
# ============================================================================
POSTGRES_USER=mes
POSTGRES_PASSWORD=mes_dev_password
POSTGRES_DB=mes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# Redis (consumed by docker-compose and apps/backend via BullMQ)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=    # leave empty for local dev

# ============================================================================
# Backend (apps/backend)
# ============================================================================
NODE_ENV=development
BACKEND_PORT=3000

# JWT — REQUIRED in production; default below is dev-only
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# CORS — comma-separated origin allow-list
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Invitation token signing
INVITATION_TOKEN_TTL_HOURS=72

# ============================================================================
# Frontends (apps/web, apps/admin) — read at build/runtime via VITE_*
# ============================================================================
WEB_PORT=5173
ADMIN_PORT=5174
VITE_API_BASE_URL=http://localhost:3000
